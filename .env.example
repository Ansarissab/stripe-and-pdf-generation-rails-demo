# Copy this file to .env (gitignored) and fill in real values for local dev.
# Production secrets are loaded by Kamal from .kamal/secrets, not from this file.

# --- Stripe ----------------------------------------------------------------
# Test keys from https://dashboard.stripe.com/test/apikeys.
# Names below are the ones Pay reads internally -- in the Stripe dashboard
# the "secret key" is STRIPE_PRIVATE_KEY and the webhook "signing secret"
# is STRIPE_SIGNING_SECRET.
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_PRIVATE_KEY=sk_test_xxx

# Webhook endpoint signing secret. From the CLI:
#   stripe listen --forward-to localhost:3000/pay/webhooks/stripe
STRIPE_SIGNING_SECRET=whsec_xxx

# Stripe Price IDs for the two demo tiers (created in the Stripe dashboard).
PAY_STRIPE_PLAN_BASIC=price_xxx
PAY_STRIPE_PLAN_PRO=price_xxx

# --- Rails -----------------------------------------------------------------
# DATABASE_URL is intentionally not set in development -- Rails will fall back
# to config/database.yml, which uses the OS user via the local PostgreSQL
# socket. Uncomment and set only if you need to override (e.g. to point at a
# remote DB). Setting it here overrides database.yml entirely.
# DATABASE_URL=postgres://user:pass@host:5432/stripe_pdf_generation_demo_development

SECRET_KEY_BASE=generate_with_bin_rails_secret
